{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "trailingComma": "all",
  "singleQuote": false,
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "experimentalSortPackageJson": false,
  "ignorePatterns": [
    "**/routeTree.gen.ts",
    "**/.output/**",
    "**/.vscode/**",
    "**/.cursor/**",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock"
  ]
}
