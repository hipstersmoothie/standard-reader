{
  "lexicon": 1,
  "id": "app.standard-reader.getPublications",
  "defs": {
    "main": {
      "type": "query",
      "description": "Browse the publication directory with topic filter, sort, and cursor pagination.",
      "parameters": {
        "type": "params",
        "properties": {
          "topic": {
            "type": "string",
            "maxLength": 128
          },
          "sort": {
            "type": "string",
            "knownValues": ["readers", "active", "az"],
            "default": "readers",
            "maxLength": 32
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60,
            "default": 24
          },
          "cursor": {
            "type": "string",
            "maxLength": 8192
          },
          "q": {
            "type": "string",
            "maxLength": 256
          }
        },
        "required": []
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "app.standard-reader.defs#cursorPagePublications"
        }
      }
    }
  }
}
