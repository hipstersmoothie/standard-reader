{
  "lexicon": 1,
  "id": "app.standard-reader.getLatestFeed",
  "defs": {
    "main": {
      "type": "query",
      "description": "Chronological feed of indexed articles with optional filter.",
      "parameters": {
        "type": "params",
        "properties": {
          "filter": {
            "type": "string",
            "knownValues": ["all", "subscriptions", "unread"],
            "default": "subscriptions"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 20
          },
          "cursor": {
            "type": "string"
          },
          "did": {
            "type": "string",
            "format": "did"
          }
        },
        "required": []
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "app.standard-reader.defs#cursorPageDocuments"
        }
      }
    }
  }
}
