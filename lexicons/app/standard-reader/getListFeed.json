{
  "lexicon": 1,
  "id": "app.standard-reader.getListFeed",
  "defs": {
    "main": {
      "type": "query",
      "description": "Chronological article feed across all publications in a list.",
      "parameters": {
        "type": "params",
        "properties": {
          "list": {
            "type": "string",
            "format": "at-uri"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 20
          },
          "cursor": {
            "type": "string"
          }
        },
        "required": ["list"]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "app.standard-reader.defs#cursorPageDocuments"
        }
      }
    }
  }
}
