{
  "lexicon": 1,
  "id": "app.standard-reader.searchDocuments",
  "defs": {
    "main": {
      "type": "query",
      "description": "Full-text search over indexed articles.",
      "parameters": {
        "type": "params",
        "properties": {
          "q": {
            "type": "string"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 20
          },
          "cursor": {
            "type": "string"
          }
        },
        "required": ["q"]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["query", "items"],
          "properties": {
            "query": {
              "type": "string"
            },
            "cursor": {
              "type": "string",
              "nullable": true
            },
            "items": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "app.standard-reader.defs#documentView"
              }
            }
          }
        }
      }
    }
  }
}
