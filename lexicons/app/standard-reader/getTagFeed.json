{
  "lexicon": 1,
  "id": "app.standard-reader.getTagFeed",
  "defs": {
    "main": {
      "type": "query",
      "description": "Articles or publications carrying a given tag.",
      "parameters": {
        "type": "params",
        "properties": {
          "tag": {
            "type": "string",
            "maxLength": 128
          },
          "view": {
            "type": "string",
            "knownValues": ["articles", "publications"],
            "default": "articles",
            "maxLength": 32
          },
          "sort": {
            "type": "string",
            "maxLength": 32
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 20
          },
          "cursor": {
            "type": "string",
            "maxLength": 8192
          }
        },
        "required": ["tag"]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["view", "items"],
          "properties": {
            "view": {
              "type": "string",
              "maxLength": 32
            },
            "cursor": {
              "type": "string",
              "nullable": true,
              "maxLength": 8192
            },
            "items": {
              "type": "array",
              "items": {
                "type": "union",
                "refs": [
                  "app.standard-reader.defs#publicationView",
                  "app.standard-reader.defs#documentView"
                ]
              }
            }
          }
        }
      }
    }
  }
}
