# Standard Reader — environment variables
#
# Copy this file to `.env` and fill in real values. `.env` / `.env.*` are gitignored
# (only `.env.example` is committed).
#
# TanStack Start env model: ONLY variables prefixed with `VITE_` are exposed to the
# browser. Everything else is server-only — keep all secrets unprefixed.

# ──────────────────────────────────────────────────────────────────────────────
# Database — Neon Postgres (read-model / cache)
# ──────────────────────────────────────────────────────────────────────────────
# Pooled connection string from the Neon dashboard (used by the app + drizzle-kit).
DATABASE_URL="postgresql://[user]:[password]@[neon_hostname]/[dbname]?sslmode=require&channel_binding=require"

# ──────────────────────────────────────────────────────────────────────────────
# App / server
# ──────────────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (no trailing slash). Used to build the AT Proto
# OAuth client_id, the client-metadata.json URL, and the OAuth redirect URI.
# Local dev example: http://127.0.0.1:3000
PUBLIC_URL="http://127.0.0.1:3000"

# Secret used to sign/encrypt session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=""

# ──────────────────────────────────────────────────────────────────────────────
# Auth — AT Proto / Bluesky OAuth
# ──────────────────────────────────────────────────────────────────────────────
# Confidential OAuth client (see @atproto/oauth-client-node). The client_id is the
# public URL of the served client-metadata.json, and the client authenticates with a
# private JWK keyset.
#
# client_id (defaults to `${PUBLIC_URL}/client-metadata.json`; override if hosted elsewhere)
ATPROTO_CLIENT_ID=""
# OAuth callback/redirect URI (defaults to `${PUBLIC_URL}/api/auth/callback`)
ATPROTO_OAUTH_REDIRECT_URI=""
# Private signing key(s) for the OAuth keyset, PKCS#8 PEM or JWK (JSON string).
# Generate e.g. with: openssl ecparam -name prime256v1 -genkey -noout -out key.pem
ATPROTO_PRIVATE_KEY_1=""
# Optional additional keys for rotation:
# ATPROTO_PRIVATE_KEY_2=""
# ATPROTO_PRIVATE_KEY_3=""

# ──────────────────────────────────────────────────────────────────────────────
# Ingestion — tap instance (backfills standard.site data into Neon)
# ──────────────────────────────────────────────────────────────────────────────
# AT Proto relay / firehose endpoint the tap subscribes to for backfill + keep-in-sync.
TAP_RELAY_URL="wss://bsky.network"
# Lexicon collection namespace(s) to index (comma-separated). Standard Reader cares about
# `standard.site` records (publications, articles, profiles, follows).
TAP_COLLECTIONS="site.standard.*"
# Where the tap persists its firehose cursor (DB-backed by default — leave blank to use
# DATABASE_URL; set a path/URL to override).
TAP_CURSOR_STORE=""
